
CC=cc
CFLAGS = -Wall -Wextra -Werror
SRCS=*.c
NAME=push_swap

all :
	@$(CC) ${CFLAGS} ${SRCS} -o push_swap
	@echo "compiled successfuly"
	

gdb :
	@$(CC)  ${SRCS} -o push_swap -g
	@echo "compiled successfuly"

nfl :
	@cc  ${SRCS} -o push_swap
	@echo "compiled successfuly"
	

clean :
	rm -f push_swap
	clear
